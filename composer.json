{
  "name": "martin3r/platform-core",
  "description": "Plattform Core Package",
  "type": "library",
  "require": {
      "laravel/socialite": "^5.0",
      "socialiteproviders/microsoft": "^4.0|dev-master",
      "openai-php/client": "^0.8.0",
      "wildbit/postmark-php": "^7.0",
      "intervention/image": "^3.11",
      "league/flysystem-aws-s3-v3": "^3.0",
    "laravel/mcp": "^0.5.7",
    "laravel/reverb": "^1.0",
    "spatie/browsershot": "^4.0"
  },
  "autoload": {
    "psr-4": {
      "Platform\\Core\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Platform\\Core\\CoreServiceProvider",
        "Platform\\Core\\Providers\\AzureSsoServiceProvider",
        "Platform\\Core\\SemanticLayer\\SemanticLayerServiceProvider"
      ]
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "php-http/discovery": true
    }
  }
}
